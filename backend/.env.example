# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Uncomment and configure ONE of the following options:

# ── Option 1: SQLite (Easiest — no setup required) ──
# DB_TYPE=sqlite
# DB_PATH=./db/equipment.sqlite

# ── Option 2: MySQL ──
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=cadmech_equipment
# DB_USER=root
# DB_PASSWORD=your_password

# ── Option 3: PostgreSQL ──
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cadmech_equipment
# DB_USER=postgres
# DB_PASSWORD=your_password
